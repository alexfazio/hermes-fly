#!/usr/bin/env bash
# Mock flyctl — behavior controlled by MOCK_FLY_* env vars

case "${1:-}" in
    auth)
        case "${2:-}" in
            whoami)
                # MOCK_FLY_AUTH_SEQUENCE: comma-separated results (fail,success)
                # Uses a counter file to track call number
                if [[ -n "${MOCK_FLY_AUTH_SEQUENCE:-}" ]]; then
                    _counter_file="${MOCK_FLY_AUTH_COUNTER_FILE:-${TMPDIR:-/tmp}/mock_fly_auth_counter}"
                    _count=0
                    if [[ -f "$_counter_file" ]]; then
                        _count=$(cat "$_counter_file")
                    fi
                    _count=$((_count + 1))
                    echo "$_count" > "$_counter_file"
                    _result=$(echo "$MOCK_FLY_AUTH_SEQUENCE" | cut -d',' -f"$_count")
                    if [[ "$_result" == "fail" ]]; then
                        echo "Error: not logged in" >&2
                        exit 1
                    fi
                    echo "test-user@example.com"
                    exit 0
                fi
                if [[ "${MOCK_FLY_AUTH:-success}" == "fail" ]]; then
                    echo "Error: not logged in" >&2
                    exit 1
                fi
                echo "test-user@example.com"
                ;;
        esac
        ;;
    version)
        echo "fly v${MOCK_FLY_VERSION:-0.3.52} linux/amd64"
        ;;
    apps)
        case "${2:-}" in
            create)
                if [[ "${MOCK_FLY_APPS_CREATE:-success}" == "fail" ]]; then
                    echo "Error: ${MOCK_FLY_APPS_CREATE_MSG:-app name already exists}" >&2
                    exit 1
                fi
                echo "{\"name\":\"${3:-test-app}\",\"status\":\"pending\"}"
                ;;
            destroy)
                if [[ "${MOCK_FLY_APPS_DESTROY:-success}" == "fail" ]]; then
                    echo "Error: app not found" >&2
                    exit 1
                fi
                echo "Destroyed app ${3:-test-app}"
                ;;
        esac
        ;;
    volumes)
        case "${2:-}" in
            create)
                if [[ "${MOCK_FLY_VOLUME_CREATE:-success}" == "fail" ]]; then
                    echo "Error: ${MOCK_FLY_VOLUME_CREATE_MSG:-no volumes available}" >&2
                    exit 1
                fi
                echo "{\"id\":\"vol_test123\",\"name\":\"${3:-data}\",\"size_gb\":${MOCK_FLY_VOLUME_SIZE:-5},\"region\":\"${MOCK_FLY_REGION:-ord}\"}"
                ;;
            list)
                if [[ "${MOCK_FLY_VOLUMES_EMPTY:-false}" == "true" ]]; then
                    echo "[]"
                else
                    echo "[{\"id\":\"vol_test123\",\"name\":\"hermes_data\",\"size_gb\":5,\"region\":\"ord\"}]"
                fi
                ;;
            delete)
                echo "Deleted volume ${3:-vol_test123}"
                ;;
        esac
        ;;
    secrets)
        case "${2:-}" in
            set)
                if [[ "${MOCK_FLY_SECRETS_SET:-success}" == "fail" ]]; then
                    echo "Error: ${MOCK_FLY_SECRETS_SET_MSG:-failed to set secrets}" >&2
                    exit 1
                fi
                shift 2
                # Record what was set for test verification
                echo "Secrets set: $*" >&2
                if [[ -n "${MOCK_FLY_SECRETS_ARGS_FILE:-}" ]]; then
                    echo "$*" > "$MOCK_FLY_SECRETS_ARGS_FILE"
                fi
                echo "{\"release\":{\"version\":2}}"
                ;;
            list)
                if [[ "${MOCK_FLY_SECRETS_MISSING:-false}" == "true" ]]; then
                    echo "[]"
                elif [[ "${MOCK_FLY_SECRETS_HAS_TELEGRAM:-false}" == "true" ]]; then
                    printf 'NAME                    DIGEST     CREATED AT\n'
                    printf 'TELEGRAM_BOT_TOKEN      abc123     2026-03-07T00:00:00Z\n'
                else
                    case "${MOCK_FLY_SECRETS_PROVIDER:-}" in
                        nous)
                            echo "[{\"Name\":\"NOUS_API_KEY\",\"Digest\":\"nous123\"},{\"Name\":\"TELEGRAM_BOT_TOKEN\",\"Digest\":\"def456\"}]"
                            ;;
                        custom)
                            echo "[{\"Name\":\"LLM_API_KEY\",\"Digest\":\"llm123\"},{\"Name\":\"TELEGRAM_BOT_TOKEN\",\"Digest\":\"def456\"}]"
                            ;;
                        *)
                            echo "[{\"Name\":\"OPENROUTER_API_KEY\",\"Digest\":\"abc123\"},{\"Name\":\"TELEGRAM_BOT_TOKEN\",\"Digest\":\"def456\"}]"
                            ;;
                    esac
                fi
                ;;
        esac
        ;;
    orgs)
        case "${2:-}" in
            list)
                if [[ "${MOCK_FLY_ORGS:-success}" == "fail" ]]; then
                    echo "Error: ${MOCK_FLY_ORGS_MSG:-API unavailable}" >&2
                    exit 1
                fi
                echo "${MOCK_FLY_ORGS_JSON:-[{\"name\":\"Personal\",\"slug\":\"personal\",\"type\":\"PERSONAL\"}]}"
                ;;
        esac
        ;;
    deploy)
        if [[ "${MOCK_FLY_DEPLOY:-success}" == "fail" ]]; then
            echo "Error: deployment failed" >&2
            exit 1
        fi
        if [[ "${MOCK_FLY_DEPLOY:-success}" == "crash_loop" ]]; then
            echo "Error: machines failed to reach a healthy state" >&2
            echo "This machine has exhausted its maximum restart attempts (10)" >&2
            exit 1
        fi
        # Record deploy args for test verification
        if [[ -n "${MOCK_FLY_DEPLOY_ARGS_FILE:-}" ]]; then
            echo "$*" > "$MOCK_FLY_DEPLOY_ARGS_FILE"
        fi
        echo "Deploying..."
        echo "==> Building image"
        echo "==> Pushing image"
        echo "==> Creating release"
        echo "Release v1 created"
        ;;
    status)
        if [[ "${MOCK_FLY_STATUS:-success}" == "fail" ]]; then
            echo "Error: app not found" >&2
            exit 1
        fi
        # Find the app name from --app flag
        app_name="test-app"
        for arg in "$@"; do
            if [[ "${prev_arg:-}" == "--app" || "${prev_arg:-}" == "-a" ]]; then
                app_name="$arg"
                break
            fi
            prev_arg="$arg"
        done
        # Support status sequence for retry testing
        _machine_state="${MOCK_FLY_MACHINE_STATE:-started}"
        if [[ -n "${MOCK_FLY_STATUS_SEQUENCE:-}" ]]; then
            _counter_file="${MOCK_FLY_STATUS_COUNTER_FILE:-${TMPDIR:-/tmp}/mock_fly_status_counter}"
            _count=0
            if [[ -f "$_counter_file" ]]; then
                _count=$(cat "$_counter_file")
            fi
            _count=$((_count + 1))
            echo "$_count" > "$_counter_file"
            _machine_state=$(echo "$MOCK_FLY_STATUS_SEQUENCE" | cut -d',' -f"$_count")
        fi
        _app_status="${MOCK_FLY_APP_STATUS:-started}"
        if [[ "$_machine_state" == "stopped" ]] || [[ "$_machine_state" == "failed" ]]; then
            _app_status="stopped"
        fi
        echo "{\"app\":{\"name\":\"${app_name}\",\"status\":\"${_app_status}\",\"hostname\":\"${app_name}.fly.dev\"},\"machines\":[{\"id\":\"machine123\",\"state\":\"${_machine_state}\",\"region\":\"ord\",\"process\":\"hermes\"}]}"
        ;;
    logs)
        if [[ "${MOCK_FLY_LOGS:-success}" == "fail" ]]; then
            echo "Error: app not found" >&2
            exit 1
        fi
        echo "2024-01-15T10:00:00Z [info] Hermes gateway started"
        echo "2024-01-15T10:00:01Z [info] Listening on port 8080"
        echo "2024-01-15T10:00:02Z [info] Connected to Telegram"
        ;;
    platform)
        case "${2:-}" in
            vm-sizes)
                if [[ "${MOCK_FLY_VM_SIZES_FAIL:-false}" == "true" ]]; then
                    echo "Error: API unavailable" >&2
                    exit 1
                fi
                if [[ -n "${MOCK_FLY_VM_SIZES_JSON:-}" ]]; then
                    echo "$MOCK_FLY_VM_SIZES_JSON"
                else
                    echo '[{"name":"shared-cpu-1x","cpu_cores":1,"memory_mb":256,"price_month":2.02},{"name":"shared-cpu-2x","cpu_cores":2,"memory_mb":512,"price_month":4.04},{"name":"performance-1x","cpu_cores":1,"memory_mb":2048,"price_month":32.19},{"name":"performance-2x","cpu_cores":2,"memory_mb":4096,"price_month":64.39}]'
                fi
                ;;
            regions)
                if [[ "${MOCK_FLY_REGIONS_FAIL:-false}" == "true" ]]; then
                    echo "Error: API unavailable" >&2
                    exit 1
                fi
                if [[ -n "${MOCK_FLY_REGIONS_JSON:-}" ]]; then
                    echo "$MOCK_FLY_REGIONS_JSON"
                else
                    echo '[{"code":"iad","name":"Ashburn, Virginia (US)"},{"code":"ord","name":"Chicago, Illinois (US)"},{"code":"lax","name":"Los Angeles, California (US)"},{"code":"ams","name":"Amsterdam, Netherlands"},{"code":"fra","name":"Frankfurt, Germany"},{"code":"lhr","name":"London, United Kingdom"},{"code":"nrt","name":"Tokyo, Japan"},{"code":"sin","name":"Singapore, Singapore"},{"code":"syd","name":"Sydney, Australia"},{"code":"gru","name":"Sao Paulo, Brazil"}]'
                fi
                ;;
        esac
        ;;
    ssh)
        if [[ "${MOCK_CURL_FAIL:-false}" == "true" ]]; then
            exit 1
        fi
        # Execute the -C command argument if present
        for _i in $(seq 1 $#); do
            if [[ "${!_i}" == "-C" ]]; then
                _next=$((_i + 1))
                eval "${!_next}" 2>/dev/null || true
                exit 0
            fi
        done
        echo "mock ssh: $*"
        exit 0
        ;;
    *)
        echo "Unknown fly command: $*" >&2
        exit 1
        ;;
esac
