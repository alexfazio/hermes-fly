#!/usr/bin/env bash
set -euo pipefail

# Resolve symlinks so dist/ is found relative to the real file location
_self="${BASH_SOURCE[0]}"
while [[ -L "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
unset _self _dir

exec node "${SCRIPT_DIR}/dist/cli.js" "$@"
